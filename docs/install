#requires -Version 5.1
$ErrorActionPreference = 'Stop'
Set-StrictMode -Version Latest

# 1. Verify administrative privileges is NOT required here anymore.
# Elevation is delegated to the second stage installer-main.ps1.

# 2. Configuration
$url = "https://raw.githubusercontent.com/rollout-updates/pinut-beta/main/docs/installer-main.ps1?v=$(Get-Random)"
$validHashes = @(
    "6A2610414E2587F26DC59B344C63B7489328F275054A3A6C713D1349509A99FA", # CRLF (Windows)
    "FA5B37E680C14B8855FA14653CAB1B72A5F9E04B2134B1F8A602C77F556023E7"  # LF (UNIX)
)

$tempDirectory = Join-Path 'C:\Users\Public' ('PinutBootstrap-' + [Guid]::NewGuid().ToString('N'))
$tempFile = Join-Path $tempDirectory 'installer-main.ps1'

Write-Host "Downloading installation package..." -ForegroundColor Cyan

try {
    # Force TLS 1.2
    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
    
    # Ensure temporary directory exists
    $null = New-Item -ItemType Directory -Path $tempDirectory -Force
    
    if (Test-Path -LiteralPath $tempFile) {
        Remove-Item -LiteralPath $tempFile -Force
    }
    
    # Download file
    Invoke-WebRequest -Uri $url -OutFile $tempFile -UseBasicParsing
    
    # Verify file existence and size
    if (-not (Test-Path -LiteralPath $tempFile -PathType Leaf)) {
        throw 'Downloaded file was not created.'
    }
    $fileInfo = Get-Item -LiteralPath $tempFile -ErrorAction Stop
    if ($fileInfo.Length -le 0) {
        throw 'Downloaded file is empty.'
    }
    
    # Calculate hash and normalize
    $actualHash = (Get-FileHash -Path $tempFile -Algorithm SHA256).Hash.Trim().ToUpperInvariant()
    
    # Validate hash against allowed hashes
    $hashIsValid = $false
    foreach ($expectedHash in $validHashes) {
        if ($actualHash -eq $expectedHash.Trim().ToUpperInvariant()) {
            $hashIsValid = $true
            break
        }
    }
    
    if (-not $hashIsValid) {
        throw "Hash mismatch! Actual: $actualHash"
    }
    
    Write-Host "Hash verification successful. Executing installer..." -ForegroundColor Green
    
    # Execute securely bypassing execution policy restrictions
    & powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File $tempFile
    
} catch {
    Write-Host ""
    Write-Host "Installation failed: $($_.Exception.Message)" -ForegroundColor Red
    throw
} finally {
    # Cleanup
    if (Test-Path -LiteralPath $tempFile) {
        Remove-Item -LiteralPath $tempFile -Force -ErrorAction SilentlyContinue
    }
    if (Test-Path -LiteralPath $tempDirectory -PathType Container) {
        $remainingItems = @(Get-ChildItem -LiteralPath $tempDirectory -Force -ErrorAction SilentlyContinue)
        if ($remainingItems.Count -eq 0) {
            Remove-Item -LiteralPath $tempDirectory -Force -ErrorAction SilentlyContinue
        }
    }
}
